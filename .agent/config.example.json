{
  "run": {
    "default": "ask",
    "allow": ["ls*", "cat*", "git status", "go build*", "go test*"],
    "deny": ["rm -rf*", "sudo*", "*| sh", "*curl*sh*"],
    "timeout_seconds": 120
  },
  "file": {
    "default": "ask",
    "jail": ".",
    "allow_write": ["**/*.go", "notes/**"],
    "deny_write": [".git/**", "**/*secret*", "**/.env*"]
  }
}
